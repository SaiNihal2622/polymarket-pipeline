# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API (required for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# CLOB V2: Deposit Wallet (required — different from your EOA address)
# Create one at https://polymarket.com — connect wallet and check "Deposit"
POLYMARKET_DEPOSIT_WALLET=0xYOUR_DEPOSIT_WALLET_HERE

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Xiaomi MiMo V2.5 Pro (primary AI — fast, uncapped, with Web Search)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=MiMo-V2.5-Pro
MIMO_WEB_SEARCH=true

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=

# Pipeline Settings
BANKROLL_USD=20
DRY_RUN=true
MAX_BET_USD=2
DAILY_LOSS_LIMIT_USD=5
EDGE_THRESHOLD=0.15
SCORING_MODEL=claude-sonnet-4-20250514

# V2 Settings
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=500
MATERIALITY_THRESHOLD=0.65
SPEED_TARGET_SECONDS=5

# V3 Consensus Settings
CONSENSUS_ENABLED=true
CONSENSUS_PASSES=2
CONSENSUS_MIN_AGREEMENT=1.0
STRICT_CONSENSUS=false

# LLM Provider Settings
LLM_PROVIDER=ollama
CLASSIFICATION_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# Sniper Bot Settings
SNIPE_BANKROLL_PCT=2.5
SNIPER_MAX_BET=50.0
SNIPER_SLIPPAGE_TOLERANCE=3.0
SNIPER_MAX_SLIPPAGE_PCT=5.0
SNIPER_KILL_SWITCH_LOSSES=5
SNIPER_DAILY_LOSS_LIMIT_PCT=15.0
SNIPER_MAX_POSITIONS=3
SNIPER_CHECK_INTERVAL=30
SNIPER_COOLDOWN_SECONDS=120
SNIPER_STOP_LOSS_PCT=30.0
SNIPER_SAFETY_CUT_PCT=50.0

# Market Maker Settings
MM_ENABLED=true
MM_MIN_PAIRED_DISCOUNT=0.02
MM_MAX_POSITION_USD=10.0
MM_MM_TRADE_SIZE_USD=5.0
MM_SPREAD_THRESHOLD=0.03
MM_TARGET_MIN_VOLUME=50000

# Real Trading (KEEP FALSE until ready)
REAL_TRADES_ENABLED=false
