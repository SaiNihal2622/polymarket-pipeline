# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API (required for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings (tuned for $20 bankroll)
BANKROLL_USD=20
DRY_RUN=true
MAX_BET_USD=2
DAILY_LOSS_LIMIT_USD=5
EDGE_THRESHOLD=0.15

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=500
MATERIALITY_THRESHOLD=0.65
SPEED_TARGET_SECONDS=5

# V3 Consensus Settings
CONSENSUS_ENABLED=true
CONSENSUS_PASSES=2
CONSENSUS_MIN_AGREEMENT=1.0
