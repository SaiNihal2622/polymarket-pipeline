// Cloudflare Worker - Reverse proxy for Polymarket CLOB API
// Bypasses geoblocking since Cloudflare edge IPs aren't blocked

export default {
  async fetch(request) {
    const url = new URL(request.url);
    const target = "https://clob.polymarket.com" + url.pathname + url.search;
    
    // Build clean headers - strip ALL identifying headers
    const headers = new Headers();
    for (const [key, value] of request.headers.entries()) {
      const lower = key.toLowerCase();
      // Skip ALL headers that could reveal the origin IP
      if (['host', 'cf-connecting-ip', 'cf-ipcountry', 'cf-ray',
           'cf-visitor', 'x-forwarded-for', 'x-forwarded-proto',
           'x-real-ip', 'forwarded', 'x-forwarded-host',
           'true-client-ip'].includes(lower)) continue;
      headers.set(key, value);
    }
    headers.set("Host", "clob.polymarket.com");
    headers.set("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36");
    // Override x-forwarded-for to a US residential IP
    headers.set("X-Forwarded-For", "73.162.45.89");
    
    const init = {
      method: request.method,
      headers,
    };
    
    if (request.method !== "GET" && request.method !== "HEAD") {
      init.body = await request.arrayBuffer();
    }
    
    const resp = await fetch(target, init);
    const respHeaders = new Headers(resp.headers);
    respHeaders.set("Access-Control-Allow-Origin", "*");
    // Strip content-encoding to prevent double-compression
    respHeaders.delete("content-encoding");
    respHeaders.delete("transfer-encoding");
    
    return new Response(resp.body, {
      status: resp.status,
      headers: respHeaders,
    });
  }
};